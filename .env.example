# AI backend — Qwen via an OpenAI-compatible API (inlined at build time by Vite).
# Locally: copy this file to .env.local and set your key.
# On Vercel: add QWEN_API_KEY as an Environment Variable in Project Settings.

# Required — your API key from the provider below.
QWEN_API_KEY=your_qwen_api_key_here

# Optional — endpoint + model. Defaults target Alibaba DashScope (international).
# You can point to any OpenAI-compatible Qwen provider by changing these:
#
#   DashScope (Alibaba, default):
#     QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#     QWEN_MODEL=qwen-plus
#
#   OpenRouter (free Qwen models available):
#     QWEN_BASE_URL=https://openrouter.ai/api/v1
#     QWEN_MODEL=qwen/qwen-2.5-72b-instruct
#
#   SiliconFlow:
#     QWEN_BASE_URL=https://api.siliconflow.cn/v1
#     QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct
#
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
